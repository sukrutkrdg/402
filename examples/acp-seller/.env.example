# x402 Bazaar — ACP seller env. Get these from Phase 1 registration
# (https://app.virtuals.io/acp/join). See README.

# GAME API key (console.game.virtuals.io)
GAME_API_KEY=
# Your registered ACP provider agent's wallet address
SELLER_AGENT_WALLET_ADDRESS=
# The dev wallet you whitelisted (signs ACP txs; gas sponsored, keep low balance)
WHITELISTED_WALLET_PRIVATE_KEY=
# Your agent's ACP entity id (a number, from registration)
SELLER_ENTITY_ID=

# x402 Bazaar origin (default https://402.com.tr)
X402_BAZAAR_ORIGIN=https://402.com.tr
