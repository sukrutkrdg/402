# ─────────────────────────────────────────────────────────────
# x402 Bazaar — environment
# Copy to ".env.local" and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Builder Codes ─────────────────────────────────────────────
# Get these from https://dashboard.base.org → register app →
# verify domain → Settings → Builder Codes.
# Pattern: ^[a-z0-9_]{1,32}$  (example format: bc_b7k3p9da)

# App code (a) — declared by the seller on every paid route.
APP_BUILDER_CODE=x402_bazaar
# Client code (s) — attached by the buyer to every payment.
CLIENT_BUILDER_CODE=x402_bazaar_cli

# ── Seller (resource server) ──────────────────────────────────
# Wallet that receives the USDC payments.
PAY_TO_ADDRESS=0xYourSellerAddress

# Coinbase CDP API key — required for Base MAINNET settlement.
# Create at https://portal.cdp.coinbase.com (Secret API Key).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── Buyer (demo client) ───────────────────────────────────────
# Private key of a wallet holding USDC + a little ETH on Base
# mainnet. Used by the built-in "Pay & call" button. SERVER ONLY.
BUYER_PRIVATE_KEY=

# ── Base App verification ─────────────────────────────────────
# The base:app_id meta tag value from base.dev (identifies your app to
# Base App / discovery). NOTE: this is NOT the x402 Builder Code — the
# Builder Code (APP_BUILDER_CODE above) is a separate short code under
# base.dev → Settings → Builder Code.
NEXT_PUBLIC_BASE_APP_ID=

# ── Public-deploy safety (recommended for Vercel) ─────────────
# Set to "false" to fully disable the demo buyer (view-only showcase).
ENABLE_BUYER=true
# If set, callers must supply this secret (UI field / x-buy-token header)
# to spend from the buyer wallet. Leave blank for local-only use.
BUY_ACCESS_TOKEN=
# Owner-only password for the private revenue dashboard at /stats.
# Set this to view earnings; without it /stats stays locked.
STATS_TOKEN=

# ── Durability & jobs (optional but recommended) ──────────────
# KV store for a global free-tier counter + usage analytics + price alerts.
# Create a free Upstash Redis (or Vercel KV) and paste either pair:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Daily free calls per IP (0 disables the free tier).
FREE_TIER_DAILY=3
# Secret for the price-alert cron endpoint (/api/cron/check-alerts).
CRON_SECRET=

# ── Telegram bot (optional showcase agent) ────────────────────
# Create a bot via @BotFather, paste its token here, then register the webhook:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://402.com.tr/api/telegram&secret_token=<SECRET>
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Token Scout agent: a Telegram channel/chat id it auto-posts new-token finds to.
# Add the bot to a channel as admin, then put the channel id here. Trigger
# /api/cron/token-scout on a schedule (Vercel cron or external) with CRON_SECRET.
TELEGRAM_SCOUT_CHAT=

# ── Farcaster agent (optional) ────────────────────────────────
# Neynar app: API key + a managed signer + webhook secret. Point a Neynar
# "cast.created" webhook (mentions of your bot) at /api/farcaster-bot.
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
NEYNAR_WEBHOOK_SECRET=

# ── Alchemy (NFT floor + full wallet portfolio) ───────────────
# Free key from alchemy.com → create app (Base Mainnet) → copy API Key.
ALCHEMY_API_KEY=
# Covalent/GoldRush key (wallet net worth, activity, age, AI Wallet Report).
# From covalenthq.com. Responses are KV-cached to conserve credits.
COVALENT_API_KEY=

# ── AI services (Claude) ──────────────────────────────────────
# Powers the AI Summarize / Extract / Translate endpoints.
# Get a key at https://console.anthropic.com . Required for those services.
ANTHROPIC_API_KEY=
# Optional: override the model. Default claude-haiku-4-5 (cheap, high margin).
# Set to claude-opus-4-8 for maximum quality at higher cost.
ANTHROPIC_MODEL=

# ── Farcaster Mini App ────────────────────────────────────────
# Public site origin (used in the manifest + embed URLs). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://402-eight.vercel.app
# accountAssociation — generate once with the Farcaster Manifest tool
# (it signs THIS domain with your Farcaster account), then paste here.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# ── Optional ──────────────────────────────────────────────────
# Custom Base mainnet RPC for reading settlement calldata.
# Defaults to viem's public Base endpoint.
BASE_RPC_URL=
